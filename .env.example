PORT=3000
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=orbit
MYSQL_PASSWORD=orbit_password
MYSQL_DATABASE=orbit
MYSQL_MIGRATE_FROM_JSON=true
PANSOU_BASE_URL=http://127.0.0.1:8888
PANSOU_TIMEOUT=12
HERMES_DASHBOARD_URL=http://127.0.0.1:9119
HERMES_DASHBOARD_PUBLIC_PATH=/hermes-dashboard
HERMES_DASHBOARD_COMMAND=hermes dashboard --host 127.0.0.1 --port 9119 --no-open
HERMES_DASHBOARD_STOP_COMMAND=hermes dashboard --stop
HERMES_DASHBOARD_TIMEOUT=5
HERMES_STREAM_COMMAND="/path/to/hermes-agent/venv/bin/python -m backend.hermes_stream_bridge"
HERMES_STREAM_POOL_SIZE=2
HERMES_STREAM_POOL_WAIT_TIMEOUT=5
HERMES_CHAT_TIMEOUT=1800
SESSION_SECRET=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=14
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
