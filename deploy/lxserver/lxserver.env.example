PORT=9527
BIND_IP=0.0.0.0
PROXY_HEADER=x-real-ip
DATA_PATH=/server/data
LOG_PATH=/server/logs
ADMIN_PATH=/_orbit_lx_admin
PLAYER_PATH=/music
FRONTEND_PASSWORD=replace-with-a-long-random-value
ENABLE_WEBPLAYER_AUTH=false
WEBPLAYER_PASSWORD=unused-behind-orbit-gateway
SUBSONIC_ENABLE=false
USER_ENABLE_PATH=false
USER_ENABLE_ROOT=false
ENABLE_PUBLIC_USER_RESTRICTION=true
ENABLE_LOGIN_USER_CACHE_RESTRICTION=true
ENABLE_CACHE_SIZE_LIMIT=true
CACHE_SIZE_LIMIT=2048
DISABLE_TELEMETRY=true
